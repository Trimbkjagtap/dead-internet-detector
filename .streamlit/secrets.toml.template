cat > .streamlit/secrets.toml.template << 'EOF'
# .streamlit/secrets.toml.template
# This is just a TEMPLATE — do NOT put real values here
# Real values go in Streamlit Cloud's Secrets dashboard

BACKEND_URL = "https://your-app.onrender.com"
NEO4J_URI = "neo4j+s://your-instance.databases.neo4j.io"
NEO4J_USERNAME = "your-username-here"
NEO4J_PASSWORD = "your-password-here"
OPENAI_API_KEY = "sk-proj-your-key-here"
WHOIS_API_KEY = "at_your-key-here"
EOF